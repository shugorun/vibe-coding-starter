{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(//**)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "PowerShell(git status:*)",
      "PowerShell(git diff:*)",
      "PowerShell(git log:*)",
      "PowerShell(git show:*)",
      "PowerShell(git branch:*)",
      "PowerShell(git rev-parse:*)",
      "PowerShell(git rev-list:*)",
      "PowerShell(git remote:*)",
      "PowerShell(git fetch:*)",
      "PowerShell(git pull:*)",
      "PowerShell(git add:*)",
      "PowerShell(git commit:*)",
      "PowerShell(git push:*)",
      "Bash(date:*)",
      "PowerShell(Get-Date:*)",
      "PowerShell(Get-ChildItem:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./**/.env.*.local)",
      "Read(./**/secrets/**)",
      "Read(./**/credentials*)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.*.local)",
      "Edit(./**/.env)",
      "Edit(./**/.env.local)",
      "Edit(./**/.env.*.local)",
      "Edit(./**/secrets/**)",
      "Edit(./**/credentials*)",
      "Write(./.env)",
      "Write(./.env.local)",
      "Write(./.env.*.local)",
      "Write(./**/.env)",
      "Write(./**/.env.local)",
      "Write(./**/.env.*.local)",
      "Write(./**/secrets/**)",
      "Write(./**/credentials*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-start.cjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/stop.cjs"
          }
        ]
      }
    ]
  }
}
